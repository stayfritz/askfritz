# Postgres
DATABASE_URL=postgres://askfritz:CHANGEME@localhost:5432/askfritz

# Anthropic
ANTHROPIC_API_KEY=

# Gmail OAuth (read mailbox — your actual business inbox)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=you@yourdomain.com
GMAIL_PUBSUB_TOPIC=projects/YOUR_GCP_PROJECT/topics/gmail-push

# Telegram command channel (you talk to Fritz here)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Dropbox OAuth (target folder: /fritzai/)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ROOT=/fritzai

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
